[
  {
    "id": "SEC-001",
    "name": "危险的 Eval 执行",
    "description": "使用 eval() 可能导致远程代码执行漏洞。",
    "severity": "critical",
    "type": "regex",
    "pattern": "eval\\(",
    "fix": "避免动态代码执行。如果是处理数据，请使用 JSON.parse()。",
    "tags": ["security", "code"],
    "group": "owasp-top10"
  },
  {
    "id": "SEC-002",
    "name": "硬编码 AWS 密钥",
    "description": "检测到硬编码的 AWS 访问密钥。",
    "severity": "high",
    "type": "regex",
    "pattern": "AKIA[0-9A-Z]{16}",
    "fix": "请使用环境变量存储敏感凭证。",
    "tags": ["security", "secret"],
    "group": "secrets"
  },
  {
    "id": "SEC-003",
    "name": "系统命令执行",
    "description": "检测到执行系统命令的操作。",
    "severity": "high",
    "type": "regex",
    "pattern": "child_process\\.exec|subprocess\\.call",
    "fix": "如果必须执行，请严格验证输入参数。",
    "tags": ["security", "code"],
    "group": "command-exec"
  },
  {
    "id": "SEC-004",
    "name": "敏感信息获取",
    "description": "检测到尝试获取密码或敏感信息的交互。",
    "severity": "medium",
    "type": "regex",
    "pattern": "(input|prompt).*password|bank.*card|credit.*card",
    "fix": "严禁直接向用户索要敏感凭证。",
    "tags": ["privacy", "interaction"],
    "group": "privacy"
  },
  {
    "id": "SEC-101",
    "name": "Eval 调用检测",
    "description": "检测到对 eval 的直接调用。",
    "severity": "critical",
    "type": "ast",
    "selector": "call:eval",
    "fix": "避免使用 eval 进行动态执行。",
    "tags": ["security", "code"],
    "group": "owasp-top10"
  },
  {
    "id": "SEC-102",
    "name": "命令执行调用检测",
    "description": "检测到执行系统命令的调用。",
    "severity": "high",
    "type": "ast",
    "selector": "call:exec",
    "fix": "如果必须执行，请严格验证输入参数。",
    "tags": ["security", "code"],
    "group": "command-exec"
  },
  {
    "id": "SEC-103",
    "name": "同步命令执行调用检测",
    "description": "检测到同步执行系统命令的调用。",
    "severity": "high",
    "type": "ast",
    "selector": "call:execSync",
    "fix": "避免同步执行命令，必要时进行严格白名单控制。",
    "tags": ["security", "code"],
    "group": "command-exec"
  },
  {
    "id": "SEC-104",
    "name": "进程创建调用检测",
    "description": "检测到创建系统进程的调用。",
    "severity": "high",
    "type": "ast",
    "selector": "call:spawn",
    "fix": "请使用白名单和参数校验控制执行范围。",
    "tags": ["security", "code"],
    "group": "command-exec"
  },
  {
    "id": "SEC-201",
    "name": "Slack Token",
    "description": "检测到 Slack 访问令牌。",
    "severity": "high",
    "type": "regex",
    "pattern": "xox[baprs]-[0-9a-zA-Z-]{10,48}",
    "fix": "请移除明文令牌并改用安全存储。",
    "tags": ["security", "secret"],
    "group": "secrets"
  },
  {
    "id": "SEC-202",
    "name": "GitHub Token",
    "description": "检测到 GitHub 访问令牌。",
    "severity": "high",
    "type": "regex",
    "pattern": "ghp_[0-9A-Za-z]{36}",
    "fix": "请移除明文令牌并改用安全存储。",
    "tags": ["security", "secret"],
    "group": "secrets"
  },
  {
    "id": "SEC-203",
    "name": "私钥内容",
    "description": "检测到私钥内容片段。",
    "severity": "critical",
    "type": "regex",
    "pattern": "-----BEGIN (RSA|EC|DSA|PRIVATE) KEY-----",
    "fix": "私钥不得明文保存，请移除并改用安全存储。",
    "tags": ["security", "secret"],
    "group": "secrets"
  },
  {
    "id": "SEC-204",
    "name": "OAuth 客户端密钥",
    "description": "检测到疑似 OAuth 客户端密钥。",
    "severity": "medium",
    "type": "regex",
    "pattern": "client_secret\\s*[:=]\\s*['\"][^'\"]{8,}['\"]",
    "fix": "请移除明文密钥并改用安全存储。",
    "tags": ["security", "secret"],
    "group": "secrets"
  },
  {
    "id": "SEC-205",
    "name": "可疑 SQL 拼接",
    "description": "检测到潜在的 SQL 字符串拼接。",
    "severity": "medium",
    "type": "regex",
    "pattern": "SELECT\\s+.*\\+.*FROM|INSERT\\s+INTO\\s+.*\\+",
    "fix": "请使用参数化查询避免 SQL 注入。",
    "tags": ["security", "code"],
    "group": "owasp-top10"
  },
  {
    "id": "SEC-206",
    "name": "硬编码密码",
    "description": "检测到疑似硬编码的密码字段。",
    "severity": "high",
    "type": "regex",
    "pattern": "(password|passwd|pwd)\\s*[:=]\\s*['\"][^'\"]{6,}['\"]",
    "fix": "请使用安全的凭证管理方案，避免明文存储密码。",
    "tags": ["security", "secret"],
    "group": "secrets"
  },
  {
    "id": "SEC-207",
    "name": "硬编码 Token",
    "description": "检测到疑似硬编码的 API Token 或 Key。",
    "severity": "high",
    "type": "regex",
    "pattern": "(token|api_key|apikey|access_key)\\s*[:=]\\s*['\"][A-Za-z0-9_\\-]{8,}['\"]",
    "fix": "请使用环境变量或密钥管理服务存储 Token。",
    "tags": ["security", "secret"],
    "group": "secrets"
  },
  {
    "id": "SEC-208",
    "name": "硬编码 JWT",
    "description": "检测到疑似 JWT 字符串。",
    "severity": "medium",
    "type": "regex",
    "pattern": "eyJ[0-9A-Za-z_\\-]{10,}\\.[0-9A-Za-z_\\-]{10,}\\.[0-9A-Za-z_\\-]{10,}",
    "fix": "请移除明文 JWT 并改用安全存储。",
    "tags": ["security", "secret"],
    "group": "secrets"
  },
  {
    "id": "SEC-209",
    "name": "禁用 TLS 校验",
    "description": "检测到关闭 TLS 证书校验的配置。",
    "severity": "high",
    "type": "regex",
    "pattern": "rejectUnauthorized\\s*:\\s*false",
    "fix": "生产环境请勿关闭 TLS 证书校验。",
    "tags": ["security", "tls"],
    "group": "tls"
  },
  {
    "id": "SEC-210",
    "name": "HTTP 明文请求",
    "description": "检测到使用明文 HTTP 的请求地址。",
    "severity": "medium",
    "type": "regex",
    "pattern": "http://[A-Za-z0-9\\-._~:/?#\\[\\]@!$&'()*+,;=%]+",
    "fix": "请使用 HTTPS 保护传输过程。",
    "tags": ["security", "tls"],
    "group": "tls"
  },
  {
    "id": "SEC-211",
    "name": "Curl 不安全参数",
    "description": "检测到 curl 使用 -k 或 --insecure。",
    "severity": "medium",
    "type": "regex",
    "pattern": "curl\\s+.*(--insecure|-k)",
    "fix": "请移除不安全参数并启用证书校验。",
    "tags": ["security", "tls"],
    "group": "tls"
  },
  {
    "id": "SEC-212",
    "name": "Python 请求关闭校验",
    "description": "检测到 requests 关闭证书校验。",
    "severity": "medium",
    "type": "regex",
    "pattern": "verify\\s*=\\s*False",
    "fix": "请移除 verify=False 并启用证书校验。",
    "tags": ["security", "tls"],
    "group": "tls"
  },
  {
    "id": "SEC-213",
    "name": "危险的 Function 构造",
    "description": "检测到 Function 构造函数的动态执行风险。",
    "severity": "high",
    "type": "regex",
    "pattern": "new\\s+Function\\(",
    "fix": "避免使用 Function 构造函数进行动态执行。",
    "tags": ["security", "code"],
    "group": "owasp-top10"
  },
  {
    "id": "SEC-214",
    "name": "不安全的 YAML 反序列化",
    "description": "检测到可能存在风险的 YAML 反序列化。",
    "severity": "medium",
    "type": "regex",
    "pattern": "yaml\\.load\\(",
    "fix": "请使用安全的 YAML 解析函数并限制输入来源。",
    "tags": ["security", "code"],
    "group": "owasp-top10"
  },
  {
    "id": "AI-001",
    "name": "提示注入指令",
    "description": "检测到尝试绕过系统指令的提示注入语句。",
    "severity": "high",
    "type": "regex",
    "pattern": "(ignore|bypass|forget)\\s+(all|previous|system)\\s+(instructions|rules)",
    "fix": "对用户输入进行指令隔离与安全过滤，避免覆盖系统提示。",
    "tags": ["ai", "prompt-injection"],
    "group": "ai-prompt"
  },
  {
    "id": "AI-002",
    "name": "系统提示泄露请求",
    "description": "检测到请求系统提示或内部规则的语句。",
    "severity": "high",
    "type": "regex",
    "pattern": "(show|reveal|print)\\s+(system|hidden|internal)\\s+(prompt|rules|instructions)",
    "fix": "拒绝输出系统提示与内部规则，并启用敏感信息屏蔽。",
    "tags": ["ai", "data-leak"],
    "group": "ai-leak"
  },
  {
    "id": "AI-003",
    "name": "跨用户上下文获取",
    "description": "检测到请求其他用户对话或上下文的语句。",
    "severity": "high",
    "type": "regex",
    "pattern": "(show|give|dump)\\s+(other|another|previous)\\s+user\\s+(chat|conversation|context)",
    "fix": "限制跨用户数据访问，隔离会话上下文。",
    "tags": ["ai", "privacy"],
    "group": "ai-leak"
  },
  {
    "id": "AI-004",
    "name": "角色混淆指令",
    "description": "检测到试图冒充系统或管理员的角色指令。",
    "severity": "medium",
    "type": "regex",
    "pattern": "(you\\s+are|act\\s+as)\\s+(system|admin|developer)",
    "fix": "固定系统角色，不允许用户输入更改角色身份。",
    "tags": ["ai", "authz"],
    "group": "ai-privilege"
  },
  {
    "id": "AI-005",
    "name": "间接提示注入来源",
    "description": "检测到从外部内容加载并执行指令的语句。",
    "severity": "medium",
    "type": "regex",
    "pattern": "(read|load|fetch)\\s+(web|url|document|file)\\s+.*(prompt|instruction)",
    "fix": "对外部内容进行安全净化并在执行前加标签隔离。",
    "tags": ["ai", "prompt-injection"],
    "group": "ai-indirect"
  },
  {
    "id": "AI-006",
    "name": "越狱指令",
    "description": "检测到疑似越狱或绕过安全限制的语句。",
    "severity": "high",
    "type": "regex",
    "pattern": "(jailbreak|do\\s+anything\\s+now|dan\\s+mode)",
    "fix": "启用越狱检测与响应策略，拒绝越权操作。",
    "tags": ["ai", "safety"],
    "group": "ai-jailbreak"
  },
  {
    "id": "AI-007",
    "name": "资源耗尽诱导",
    "description": "检测到可能导致资源耗尽的高成本请求。",
    "severity": "medium",
    "type": "regex",
    "pattern": "(repeat|loop)\\s+(forever|until)\\s+(you\\s+crash|out\\s+of\\s+memory)",
    "fix": "设置请求配额与最大 token/时长限制。",
    "tags": ["ai", "abuse"],
    "group": "ai-abuse"
  },
  {
    "id": "AI-008",
    "name": "恶意代码生成请求",
    "description": "检测到请求生成恶意代码或漏洞利用代码的语句。",
    "severity": "high",
    "type": "regex",
    "pattern": "(write|generate).*(malware|ransomware|exploit|ddos)",
    "fix": "拒绝生成有害代码，并输出安全替代建议。",
    "tags": ["ai", "safety"],
    "group": "ai-output"
  },
  {
    "id": "AI-009",
    "name": "PII 泄露请求",
    "description": "检测到请求个人身份信息的语句。",
    "severity": "high",
    "type": "regex",
    "pattern": "(social\\s+security\\s+number|ssn|passport\\s+number|credit\\s+card|phone\\s+number|home\\s+address)",
    "fix": "对 PII 输出进行严格拦截与脱敏。",
    "tags": ["ai", "privacy"],
    "group": "ai-privacy"
  },
  {
    "id": "AI-010",
    "name": "认证绕过暗示",
    "description": "检测到绕过认证或获取管理员访问的语句。",
    "severity": "high",
    "type": "regex",
    "pattern": "(bypass|skip)\\s+(login|auth|authentication)|admin\\s+access\\s+without\\s+login",
    "fix": "强制身份校验与最小权限控制。",
    "tags": ["ai", "authz"],
    "group": "ai-auth"
  },
  {
    "id": "AI-011",
    "name": "系统提示拼接用户输入",
    "description": "检测到系统提示与用户输入进行字符串拼接的模式。",
    "severity": "high",
    "type": "regex",
    "pattern": "(systemPrompt|system_prompt|sysPrompt)\\s*[:=].*\\+.*(userInput|input|prompt|message)",
    "fix": "系统提示应为静态常量，不应与用户输入拼接。",
    "tags": ["ai", "prompt-injection"],
    "group": "ai-prompt"
  },
  {
    "id": "AI-012",
    "name": "模型输出驱动命令执行",
    "description": "检测到模型输出直接用于系统命令执行的模式。",
    "severity": "critical",
    "type": "regex",
    "pattern": "(exec|spawn|execSync)\\([^\\)]*(llm|model|assistant|completion|response|output)",
    "fix": "禁止将模型输出直接用于命令执行，应使用白名单与参数校验。",
    "tags": ["ai", "code"],
    "group": "ai-tool"
  },
  {
    "id": "AI-013",
    "name": "外部内容注入到提示",
    "description": "检测到将外部内容直接拼接到提示的模式。",
    "severity": "high",
    "type": "regex",
    "pattern": "(prompt|messages|systemPrompt).*(fetch|http|https|url|file)\\s*\\(",
    "fix": "外部内容应进行安全净化与标注隔离，避免提示注入。",
    "tags": ["ai", "prompt-injection"],
    "group": "ai-indirect"
  },
  {
    "id": "AI-014",
    "name": "日志输出提示内容",
    "description": "检测到将提示或模型输出写入日志的模式。",
    "severity": "medium",
    "type": "regex",
    "pattern": "(console\\.log|logger\\.info|logger\\.debug)\\(.*(prompt|systemPrompt|messages|completion|response)",
    "fix": "避免在日志中输出提示与模型输出，必要时进行脱敏。",
    "tags": ["ai", "privacy"],
    "group": "ai-leak"
  },
  {
    "id": "AI-015",
    "name": "关闭安全过滤或审核",
    "description": "检测到禁用安全过滤或审核的配置。",
    "severity": "high",
    "type": "regex",
    "pattern": "(safety|moderation|guardrails)\\s*[:=]\\s*(false|off|disabled)",
    "fix": "生产环境应启用安全过滤与内容审核。",
    "tags": ["ai", "safety"],
    "group": "ai-safety"
  },
  {
    "id": "AI-016",
    "name": "未设定最大 token 或超长生成",
    "description": "检测到未限制最大 token 或显式允许超长生成的配置。",
    "severity": "medium",
    "type": "regex",
    "pattern": "(max_tokens|maxTokens)\\s*[:=]\\s*(0|null|undefined)|allow\\s*long\\s*output",
    "fix": "设置合理的最大 token 与输出长度限制，防止资源滥用。",
    "tags": ["ai", "abuse"],
    "group": "ai-abuse"
  }
]
